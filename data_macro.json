import requests, json, time
from bs4 import BeautifulSoup

def update_calendar():
    try:
        # On interroge Forex Factory
        r = requests.get("https://www.forexfactory.com/calendar", timeout=10)
        soup = BeautifulSoup(r.text, 'html.parser')
        events = []
        # Extraction des 3 prochains événements (sélection simplifiée)
        for row in soup.select('.calendar__row--day-event')[:3]:
            title = row.select_one('.calendar__event-title').text.strip()
            date = row.select_one('.calendar__date').text.strip()
            events.append({"name": title, "date": date})
        
        # Mise à jour du fichier JSON pour le Dashboard
        with open("data_macro.json", "w") as f:
            json.dump({"events": events}, f)
    except:
        pass # En cas d'échec réseau, on garde l'ancien fichier pour ne rien casser

while True:
    update_calendar()
    time.sleep(3600) # Mise à jour toutes les heures
